# Firebase (client) — copy to .env from Firebase Console → Web app config.
# Use plain values only: no quotes, no commas (do not paste the whole JS object).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional: register service worker on localhost (push / caching demos). Production registers by default.
# VITE_REGISTER_SERVICE_WORKER=true
# Optional: show "Fill admin / clinician" on login (omit in public production).
# VITE_SHOW_LOGIN_DEMO_FILL=true

# --- Server-only secrets (never use VITE_ prefix — not exposed to the browser) ---
# Groq API for the clinical assistant (see src/server/groq-proxy.ts).
# Local dev: add to .env.
# Vercel: Project → Settings → Environment Variables (Production / Preview) — same names, no VITE_ prefix.
# Cloudflare Workers: wrangler secret put GROQ_API_KEY
# GROQ_API_KEY=
# Optional override (default llama-3.1-8b-instant):
# GROQ_MODEL=llama-3.1-8b-instant

# --- Vercel: Firebase client vars ---
# Add the same VITE_FIREBASE_* names in Vercel → Environment Variables.
# They are baked in at build time; do not commit a real .env file.
